{{- if eq .osid "linux-cachyos" "linux-arch" -}}
#!/bin/sh
# vim:ft=sh

info_msg() {
  echo -e "\n\033[1;32m${1}\033[0m"
}

XDG_DATA_HOME="$HOME/.local/share"

# Installing Niri with AGS
{{- if eq .wm "niri" }}

info_msg "Installing Niri ..."
paru -S --needed niri xwayland-satellite xdg-desktop-portal-gtk xdg-desktop-portal-gnome foot \
  awww wl-clipboard

{{- if not (lookPath "nsticky") }}
info_msg "Installing Nsticky ..."
mkdir -p "$HOME/Documents/github"
git clone https://github.com/lonerOrz/nsticky.git "$HOME/Documents/github/nsticky" &&
  cd "$HOME/Documents/github/nsticky"
cargo build --release
cp target/release/nsticky "$HOME/.local/bin"
{{- end }}

# Installing Hyprland with AGS or BSPWM with EWW
{{ else if eq .wm "hyprland" }}

info_msg "Installing Hyprland ..."
paru -S --needed hyprland xdg-desktop-portal-hyprland foot awww wl-clipboard \
  hyprsunset grim satty hyprlock

info_msg "Installing AGS ..."
export GOPATH="$XDG_DATA_HOME/go"
paru -S --needed aylurs-gtk-shell-git libastal-meta gvfs dart-sass
cd "$HOME/.config/ags/" && ags types -u
npm install
ags bundle app.ts app
chmod +x app

# Installing BSPWM with EWW
{{ else if eq .wm "bspwm" }}

info_msg "Installing BSPWM ..."
paru -S --needed xf86-video-amdgpu bspwm sxhkd sx rofi-emoji xorg-server xdo xdotool \
  xorg-xrandr xorg-xkill xorg-xset xorg-xsetroot redshift xorg-xclip xorg-setxkbmap flameshot

info_msg "Installing EWW ..."
export RUSTUP_HOME="$XDG_DATA_HOME/rustup"
paru -S --needed eww-git

{{- end -}}

# Installing Anyrun
{{- if eq .wm "niri" "hyprland" -}}
{{-   if not (lookPath "anyrun") }}
info_msg "Installing Anyrun ..."
git clone https://github.com/anyrun-org/anyrun "$HOME/Documents/github/anyrun" &&
  cd "$HOME/Documents/github/anyrun"

cargo build --release
cargo install --path anyrun/

mkdir -p "$HOME/.config/anyrun/plugins"
cp target/release/*.so "$HOME/.config/anyrun/plugins"

{{-   end -}}
{{- end -}}
{{- end -}}
